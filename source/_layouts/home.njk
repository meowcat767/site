---
layout: base.njk
templateClass: tmpl-home
---

<div class="wrapper home">
  <div class="content">

    <div class="wii-system-menu" id="wiiMenuSystem">
      <button class="wii-arrow wii-arrow-prev" id="wiiPrevBtn" aria-label="Previous Page" disabled></button>

      <div class="wii-menu-container">

        <div class="wii-menu-view active" id="wiiMainView">
          <ul class="wii-list-page active" data-page="1">
            <li>
              <button class="wii-btn-capsule wii-btn-trigger" id="wiiNavTrigger">Navigation</button>
            </li>
            <li>
              <button class="wii-btn-capsule wii-btn-trigger" id="wiiBlogTrigger">Blog</button>
            </li>
            <li>
              <a href="/projects" class="wii-btn-capsule">Portfolio</a>
            </li>
          </ul>
        </div>

        <div class="wii-menu-view" id="wiiNavView">
          <ul class="wii-list-page active">
            <li><a href="/about">About Me</a></li>
            <li><a href="/posts">View all posts archives</a></li>
            <li><a href="/projects">Portfolio</a></li>
            <li>
              <button class="wii-btn-capsule wii-btn-back-link wii-back-btn">戻る (Back)</button>
            </li>
          </ul>
        </div>

        <div class="wii-menu-view" id="wiiBlogView">
          {# Dynamically chunk your blog posts into sets of 3 per page so a Back button fits #}
          {%- for post in collections.posts -%}
            {%- if loop.index0 % 3 == 0 -%}
              <ul class="wii-list-page{% if loop.index0 == 0 %} active{% endif %}" data-blog-page="{{ (loop.index0 / 3) + 1 }}">
            {%- endif -%}

              <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>

            {%- if loop.index0 % 3 == 2 or loop.last -%}
              <li>
                <button class="wii-btn-capsule wii-btn-back-link wii-back-btn">(Back)</button>
              </li>
              </ul>
            {%- endif -%}
          {%- endfor -%}
        </div>

      </div>

      <button class="wii-arrow wii-arrow-next" id="wiiNextBtn" aria-label="Next Page" disabled></button>
    </div>

  </div>
</div>

<script>
  (function() {
    function initWiiMenu() {
      let currentView = "main";
      let blogPage = 1;

      const mainView = document.getElementById("wiiMainView");
      const navView = document.getElementById("wiiNavView");
      const blogView = document.getElementById("wiiBlogView");

      const blogPages = blogView ? blogView.querySelectorAll(".wii-list-page") : [];
      const totalBlogPages = blogPages.length;

      const prevBtn = document.getElementById("wiiPrevBtn");
      const nextBtn = document.getElementById("wiiNextBtn");

      const navTrigger = document.getElementById("wiiNavTrigger");
      const blogTrigger = document.getElementById("wiiBlogTrigger");
      const backButtons = document.querySelectorAll(".wii-back-btn");

      if (!mainView || !navView || !blogView) return;

      function updateMenuVisibility() {
        mainView.classList.remove("active");
        navView.classList.remove("active");
        blogView.classList.remove("active");

        if (currentView === "main") {
          mainView.classList.add("active");
          prevBtn.disabled = true;
          nextBtn.disabled = true;
        }
        else if (currentView === "nav") {
          navView.classList.add("active");
          prevBtn.disabled = true;
          nextBtn.disabled = true;
        }
        else if (currentView === "blog") {
          blogView.classList.add("active");
          blogPages.forEach(page => {
            page.classList.remove("active");
            if (parseInt(page.dataset.blogPage) === blogPage) {
              page.classList.add("active");
            }
          });
          prevBtn.disabled = (blogPage === 1);
          nextBtn.disabled = (blogPage === totalBlogPages || totalBlogPages === 0);
        }
      }

      prevBtn.addEventListener("click", (e) => {
        e.preventDefault();
        if (currentView === "blog" && blogPage > 1) {
          blogPage--;
          updateMenuVisibility();
        }
      });

      nextBtn.addEventListener("click", (e) => {
        e.preventDefault();
        if (currentView === "blog" && blogPage < totalBlogPages) {
          blogPage++;
          updateMenuVisibility();
        }
      });

      if (navTrigger) {
        navTrigger.addEventListener("click", () => {
          currentView = "nav";
          updateMenuVisibility();
        });
      }

      if (blogTrigger) {
        blogTrigger.addEventListener("click", () => {
          currentView = "blog";
          blogPage = 1;
          updateMenuVisibility();
        });
      }

      backButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          currentView = "main";
          updateMenuVisibility();
        });
      });

      updateMenuVisibility();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initWiiMenu);
    } else {
      initWiiMenu();
    }
  })();
</script>