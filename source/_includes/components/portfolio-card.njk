{% macro portcard(project) %}
<a href="{{ project.url }}" class="wii-portfolio-card">
  <div class="wii-portfolio-card__banner">
    {% if project.data.image %}
      <img src="/assets/{{ project.data.image }}" alt="{{ project.data.title }}" class="wii-portfolio-card__img">
    {% else %}
      <div class="wii-portfolio-card__img-placeholder">📁</div>
    {% endif %}
  </div>
  <div class="wii-portfolio-card__body">
    <span class="wii-portfolio-card__title">{{ project.data.title }}</span>
    {% if project.data.description %}
      <span class="wii-portfolio-card__desc">{{ project.data.description }}</span>
    {% endif %}
    <div class="wii-portfolio-card__meta">
      {% if project.data.lang %}<span class="wii-portfolio-card__tag">{{ project.data.lang }}</span>{% endif %}
      {% if project.data.date %}<span class="wii-portfolio-card__date">{{ project.data.date }}</span>{% endif %}
    </div>
  </div>
</a>
{% endmacro %}
