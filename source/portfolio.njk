---
layout: base.njk
title: Portfolio
templateClass: tmpl-projects
---

<div class="wii-savedata-shell">

  <div class="wii-savedata-topbar">
    <div class="wii-savedata-tabs">
      <span class="wii-savedata-tab active">SD Card</span>
    </div>
    <span class="wii-savedata-blockcount">Blocks Used: {{ collections.projects.length }}</span>
  </div>

  <div class="wii-savedata-grid" id="savegrid">

    {% for project in collections.projects %}
      <button class="wii-slot wii-slot--filled"
        data-title="{{ project.data.title }}"
        data-desc="{{ project.data.description or '' }}"
        data-lang="{{ project.data.lang or '' }}"
        data-date="{{ project.data.date or '' }}"
        data-url="{{ project.url }}"
        data-img="{% if project.data.image %}/assets/{{ project.data.image }}{% endif %}">
        <div class="wii-slot__thumb">
          {% if project.data.image %}
            <img src="/assets/{{ project.data.image }}" alt="{{ project.data.title }}">
          {% else %}
            <span class="wii-slot__icon">?</span>
          {% endif %}
        </div>
        <span class="wii-slot__label">{{ project.data.title }}</span>
      </button>
    {% endfor %}

    {% set totalItems = collections.projects.length %}
    {% if totalItems < 12 %}
      {% for i in range(totalItems, 12) %}
        <div class="wii-slot wii-slot--empty"></div>
      {% endfor %}
    {% endif %}

  </div>

  <div class="wii-savedata-bottombar">
    <a href="/" class="wii-savedata-back">Back</a>
  </div>

</div>

<!-- Detail modal -->
<div class="wii-modal-overlay" id="wiiModal" hidden>
  <div class="wii-modal" role="dialog" aria-modal="true">
    <button class="wii-modal__close" id="wiiModalClose" aria-label="Close">✕</button>
    <div class="wii-modal__art">
      <img id="wiiModalImg" src="" alt="">
      <div class="wii-modal__art-placeholder" id="wiiModalPlaceholder">📁</div>
    </div>
    <div class="wii-modal__info">
      <div class="wii-modal__header">
        <h2 class="wii-modal__title" id="wiiModalTitle"></h2>
        <div class="wii-modal__badges">
          <span class="wii-modal__badge wii-modal__badge--lang" id="wiiModalLang"></span>
          <span class="wii-modal__badge wii-modal__badge--date" id="wiiModalDate"></span>
        </div>
      </div>
      <p class="wii-modal__desc" id="wiiModalDesc"></p>
      <div class="wii-modal__actions">
        <a class="wii-modal__btn wii-modal__btn--primary" id="wiiModalLink" href="#">View Project</a>
        <button class="wii-modal__btn wii-modal__btn--cancel" id="wiiModalCancel">Cancel</button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const modal    = document.getElementById('wiiModal');
  const closeBtn = document.getElementById('wiiModalClose');
  const cancelBtn= document.getElementById('wiiModalCancel');
  const img      = document.getElementById('wiiModalImg');
  const placeholder = document.getElementById('wiiModalPlaceholder');
  const titleEl  = document.getElementById('wiiModalTitle');
  const langEl   = document.getElementById('wiiModalLang');
  const dateEl   = document.getElementById('wiiModalDate');
  const descEl   = document.getElementById('wiiModalDesc');
  const linkEl   = document.getElementById('wiiModalLink');

  function openModal(slot) {
    const d = slot.dataset;
    titleEl.textContent = d.title || '';
    descEl.textContent  = d.desc  || '';
    langEl.textContent  = d.lang  || '';
    dateEl.textContent  = d.date  || '';
    linkEl.href         = d.url   || '#';

    langEl.hidden = !d.lang;
    dateEl.hidden = !d.date;

    if (d.img) {
      img.src = d.img;
      img.alt = d.title;
      img.hidden = false;
      placeholder.hidden = true;
    } else {
      img.hidden = true;
      placeholder.hidden = false;
    }

    modal.hidden = false;
    document.body.classList.add('modal-open');
    cancelBtn.focus();
  }

  function closeModal() {
    modal.hidden = true;
    document.body.classList.remove('modal-open');
  }

  document.querySelectorAll('.wii-slot--filled').forEach(slot => {
    slot.addEventListener('click', () => openModal(slot));
  });

  closeBtn.addEventListener('click', closeModal);
  cancelBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
})();
</script>
