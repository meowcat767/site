<div class="sidebar-right">


    <div class="character-mascot">
        <img src="/bocchi.webp" alt="Bocchi" />
    </div>

</div>

<style>
    .sidebar-right {
        display: flex;
        flex-direction: column;
        gap: 15px;
        position: relative; /* Keeps character aligned relative to the column */
        height: 100%; /* Ensure sidebar takes full height of the grid cell */
    }

    .poster-group {
        background: linear-gradient(to bottom, #4a75d5, #2a4fa3);
        border: 2px solid #ffffff;
        border-radius: 8px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.15);
        overflow: hidden;
    }

    .poster-group h3 {
        background-color: #1e3c82;
        color: #ffffff;
        margin: 0;
        padding: 6px 10px;
        font-size: 0.9rem;
        text-align: center;
        border-bottom: 1px solid #ffffff;
    }

    .poster-stack {
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: center;
    }

    .poster-card img {
        width: 100%;
        max-width: 180px;
        height: auto;
        border: 2px solid #ffffff;
        border-radius: 4px;
        box-shadow: 0px 2px 4px rgba(0,0,0,0.3);
        display: block;
    }

    /* Character position styling */
    .character-mascot {
        margin-top: auto; /* Pushes mascot to the bottom of the flex container */
        position: sticky;
        bottom: 20px; /* Distance from the bottom of the viewport when sticky */
        display: flex;
        justify-content: center;
        padding-top: 20px;
    }

    .character-mascot img {
        width: 110%; /* Slightly wider than container to create the pop-out overlay effect */
        height: auto;
        max-width: 240px;
        filter: drop-shadow(3px 5px 5px rgba(0,0,0,0.3));
    }
</style>