<style>
    /* Styling scoped specifically to this sidebar component */
    .sidebar-left {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .menu-group {
        background: linear-gradient(to bottom, #4a75d5, #2a4fa3); /* Example web-safe gloss gradient */
        border: 2px solid #ffffff;
        border-radius: 8px;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.15);
        overflow: hidden;
    }

    .menu-group h3 {
        background-color: #1e3c82;
        color: #ffffff;
        margin: 0;
        padding: 6px 10px;
        font-size: 0.9rem;
        text-align: center;
        border-bottom: 1px solid #ffffff;
    }

    .menu-group ul {
        list-style: none;
        margin: 0;
        padding: 5px 0;
    }

    .menu-group li a {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        color: #ffffff;
        text-decoration: none;
        font-size: 0.85rem;
    }

    .menu-group li a:hover {
        background-color: rgba(255, 255, 255, 0.2);
    }

    .menu-group img {
        width: 16px;
        height: 16px;
        object-fit: contain;
    }

    /* Mini Music Player Box */
    .music-player-widget {
        background-color: #3b5ca8;
        border-top: 2px solid #ffffff;
        padding: 8px;
        text-align: center;
    }

    .player-title {
        color: #fff;
        font-size: 0.75rem;
        margin-bottom: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .player-buttons {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
    }

    .player-buttons button {
        background: linear-gradient(to bottom, #7293eb, #3b63cc);
        border: 1px solid #fff;
        color: white;
        border-radius: 4px;
        font-size: 0.75rem;
        padding: 3px;
        cursor: pointer;
    }

    .player-buttons button:active {
        background: #234494;
    }
</style>