---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
	<article class="content-box">
		<div class="box-header">
			{post.data.title}
			<div class="date">{post.data.pubDate.toLocaleDateString('en-GB')}</div>
		</div>
		<div class="box-body blog-post-content">
			<Content />
		</div>
        <div class="box-footer">
            <a href="/" class="back-link">← Back to Home</a>
        </div>
	</article>
</BaseLayout>

<style>
	.content-box {
		background-color: #a4c2f4;
		border: 2px solid #5b92f4;
		border-radius: 8px;
		margin-bottom: 15px;
		overflow: hidden;
		box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
	}

	.box-header {
		background: linear-gradient(to bottom, #72a3f7, #3b82f6);
		color: white;
		padding: 10px;
		font-weight: bold;
		text-align: center;
		border-bottom: 2px solid #5b92f4;
		text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
	}

    .date {
        font-size: 0.8rem;
        font-weight: normal;
        margin-top: 4px;
        opacity: 0.9;
    }

	.box-body {
		padding: 20px;
        color: #1e3c82;
        line-height: 1.6;
	}

    .blog-post-content :global(h1), .blog-post-content :global(h2), .blog-post-content :global(h3) {
        color: #163a8a;
    }

    .blog-post-content :global(p) {
        margin-bottom: 1rem;
    }

    .box-footer {
        background: rgba(255,255,255,0.2);
        padding: 10px;
        border-top: 1px solid #5b92f4;
        text-align: center;
    }

    .back-link {
        color: #163a8a;
        text-decoration: none;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .back-link:hover {
        text-decoration: underline;
    }
</style>
