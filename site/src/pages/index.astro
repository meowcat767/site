---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home Page - meowcat767's site">
	<div class="content-box main-banner">
		<div class="box-header">Home Page</div>
		<div class="box-body banner-container">
			<img src="/banner.jpg" alt="Landscape Banner" class="banner-img" />
		</div>
	</div>

	<div class="content-box welcome-section">
		<div class="box-body welcome-text">
			<p>
				<img src="/hi-kirby.png" alt="Hi Kirby" class="inline-kirby" />
				Welcome to my personal website! This is a place for me to talk about various things, but things that most people don't care about.
				You can sign my guestbook though?
			</p>
		</div>
	</div>

	<div class="content-box microblog">
		<div class="box-header">Updates<span class="rss-link">RSS</span></div>
		<div class="box-body blog-scroll">
			<ul class="blog-list">
				<li>25/05/2026 - New website!!!</li>
			</ul>
		</div>
	</div>

	<div class="button-strip">
	</div>
</BaseLayout>

<style>
	.content-box {
		background-color: #a4c2f4; /* Light blue box background */
		border: 2px solid #5b92f4;
		border-radius: 8px;
		margin-bottom: 15px;
		overflow: hidden;
		box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
	}

	.box-header {
		background: linear-gradient(to bottom, #72a3f7, #3b82f6);
		color: white;
		padding: 5px 10px;
		font-weight: bold;
		text-align: center;
		border-bottom: 2px solid #5b92f4;
		text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
	}

	.box-body {
		padding: 10px;
	}

	.banner-img {
		width: 100%;
		display: block;
		border-radius: 4px;
	}

	.welcome-text p {
		margin: 0;
		line-height: 1.5;
		color: #1e3c82;
		font-size: 0.95rem;
	}

	.inline-kirby {
		float: left;
		margin-right: 10px;
		width: 40px;
	}

	.blog-scroll {
		background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px),
						  linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px);
		background-size: 20px 20px;
		height: 200px;
		overflow-y: scroll;
	}

	.blog-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.blog-list li {
		padding: 10px;
		border-bottom: 1px dashed #5b92f4;
		color: #0b1d4a;
		font-size: 0.9rem;
	}

	.date {
		font-weight: bold;
		color: #163a8a;
	}

	.rss-link {
		color: #ff9900;
	}

	.button-strip {
		display: flex;
		flex-wrap: wrap;
		gap: 5px;
		justify-content: center;
		padding-top: 10px;
	}

	.button-strip img {
		height: 31px;
	}
</style>
