---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Site Info - meowcat767's Website">
	<div class="content-box">
		<div class="box-header">Site Info</div>
		<div class="box-body">
			<p>This website was created to share my interests and projects with the world. It is built using Astro and themed with a Frutiger Aero aesthetic, reminiscent of the mid-2000s web.</p>
            <p>The site features various sections including personal info, games, and a guestbook.</p>
		</div>
	</div>

    <div class="content-box">
        <div class="box-header">Credits</div>
        <div class="box-body">
            <ul>
                <li><strong>Framework:</strong> Astro</li>
                <li><strong>Icons:</strong> Oxygen Icons</li>
                <li><strong>Theme:</strong> Frutiger Aero / Skeuomorphism</li>
            </ul>
        </div>
    </div>
</BaseLayout>

<style>
	.content-box {
		background-color: #a4c2f4;
		border: 2px solid #5b92f4;
		border-radius: 8px;
		margin-bottom: 15px;
		overflow: hidden;
		box-shadow: 2px 2px 5px rgba(0,0,0,0.1);
	}

	.box-header {
		background: linear-gradient(to bottom, #72a3f7, #3b82f6);
		color: white;
		padding: 5px 10px;
		font-weight: bold;
		text-align: center;
		border-bottom: 2px solid #5b92f4;
		text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
	}

	.box-body {
		padding: 10px;
        color: #1e3c82;
        line-height: 1.5;
	}

    .box-body p {
        margin: 0 0 10px 0;
    }

    .box-body ul {
        margin: 0;
        padding-left: 20px;
    }
</style>
