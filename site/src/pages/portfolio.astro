---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Portfolio - meowcat767's website">
  <div class="content-box">
    <div class="box-header">Portfolio</div>
    <div class="box-body">
      <p>This is a listing of websites/apps I have built for people/myself.</p>
    </div>
    <div class="port-grid">
      <div class="port-item">
        <div class="port-title">mastertonroofing.com</div>
        <div class="port-desc">
          A professional website written for Masterton Roofing in PHP.
          <br />
          Vist it at <a href="https://mastertonroofing.com"
            >mastertonroofing.com</a
          >
        </div>
      </div>
      <div class="port-item">
        <div class="port-title">meowcat.site</div>
        <div class="port-desc">
          The site you are on right now!
          <br />
          Looks good, doesn't it?
        </div>
      </div>
    </div>
  </div>

  <style>
    .content-box {
      background-color: #a4c2f4;
      border: 2px solid #5b92f4;
      border-radius: 8px;
      margin-bottom: 15px;
      overflow: hidden;
      box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.1);
    }

    .box-header {
      background: linear-gradient(to bottom, #72a3f7, #3b82f6);
      color: white;
      padding: 5px 10px;
      font-weight: bold;
      text-align: center;
      border-bottom: 2px solid #5b92f4;
      text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
    }

    .box-body {
      padding: 10px;
      color: #1e3c82;
      line-height: 1.5;
    }

    .port-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .port-item {
      background: rgba(255, 255, 255, 0.4);
      border: 1px solid #5b92f4;
      border-radius: 6px;
      padding: 10px;
    }

    .port-title {
      font-weight: bold;
      color: #0b1d4a;
      margin-bottom: 5px;
    }

    .port-desc {
      font-size: 0.85rem;
    }

    @media (max-width: 600px) {
      .port-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
